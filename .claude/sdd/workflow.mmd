flowchart TB
  classDef agent fill:#1e3a5f,stroke:#5b9bd5,color:#fff;
  classDef gate fill:#5a1e1e,stroke:#d55b5b,color:#fff;
  classDef orch fill:#1e5a32,stroke:#5bd58a,color:#fff;
  classDef file fill:#2a2a2a,stroke:#888,color:#ddd;

  ORCH(["/sdd-auto (orchestrator)"]):::orch

  %% ---- artifacts ----
  REQ[/"requirements/REQUIREMENT.md"/]:::file
  PLAN[/"plan/PLAN.md"/]:::file
  TGT[/".sdd/target.md"/]:::file
  SPECS[/"specs/** + specs/indexes/**"/]:::file
  REUSE[/"specs/REUSE-REPORT.md"/]:::file
  IMPL[/".sdd/impl-notes/**"/]:::file
  SRC[/"src/**"/]:::file
  TESTS[/"tests/**"/]:::file
  REPORT[/"tests/REPORT.md"/]:::file
  STATE[/".sdd/state.md (verdicts)"/]:::file
  STATUS[/"index status column"/]:::file

  %% ================= PHASE A — PLAN =================
  ORCH -- writes --> REQ
  REQ --> PA[plan-architect]:::agent
  TGT -. existing .-> PA
  PA -- writes --> PLAN
  PA -- writes --> TGT
  REQ --> PG{plan-gatekeeper}:::gate
  PLAN --> PG
  TGT --> PG
  PG -- verdict --> STATE
  PG -. REJECT .-> PA

  %% ================= STEP 7 — SPECIFY =================
  PLAN --> SW[spec-writer]:::agent
  REQ --> SW
  TGT --> SW
  REUSE -. handoff edits .-> SW
  SW -- writes --> SPECS
  SPECS --> RA[reuse-analyst]:::agent
  TGT --> RA
  RA -- writes --> SPECS
  RA -- writes --> REUSE
  SPECS --> AG{analysis-gatekeeper}:::gate
  REUSE --> AG
  REQ --> AG
  AG -- verdict --> STATE
  AG -. "REJECT: spec-writer / reuse-analyst" .-> SW

  %% ================= STEP 8 — IMPLEMENT =================
  SPECS --> CI[code-implementer]:::agent
  TGT --> CI
  IMPL -. prior .-> CI
  SRC -. existing .-> CI
  CI -- writes --> SRC
  CI -- writes --> IMPL
  SPECS --> CG{code-gatekeeper}:::gate
  SRC --> CG
  IMPL --> CG
  CG -- verdict --> STATE
  CG -. "REJECT: code-implementer / spec-writer" .-> CI

  %% ================= STEP 9 — TEST =================
  SPECS -- "behavioral sections only" --> TW[test-writer]:::agent
  TGT --> TW
  TW -- writes --> TESTS
  TESTS --> TR[test-runner]:::agent
  SRC --> TR
  TGT --> TR
  TR -- writes --> REPORT
  REPORT --> TG{test-gatekeeper}:::gate
  SPECS --> TG
  TESTS --> TG
  SRC --> TG
  TG -- verdict --> STATE
  TG -. "REJECT: spec / code / test / escalate" .-> TW

  %% ================= ORCHESTRATION =================
  STATE -- reads --> ORCH
  ORCH -- "advances on PASS" --> STATUS
